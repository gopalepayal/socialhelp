@{
    ViewData["Title"] = "Home";
}

<!-- ─── Hero Section with Image ──────────────────────────────────────────────── -->
<section class="hero-img" data-aos="fade-in">
    <img src="~/images/hero-banner.png" alt="Helping Communities Together" class="hero-bg-img" />
    <div class="hero-overlay"></div>
    <div class="container hero-content">
        <div class="hero-badges" data-aos="fade-down" data-aos-delay="100">
            <span class="badge-pill"><i class="bi bi-house-heart me-1"></i> Orphanages</span>
            <span class="badge-pill"><i class="bi bi-eye me-1"></i> Blind Schools</span>
            <span class="badge-pill"><i class="bi bi-person-arms-up me-1"></i> Old Age Homes</span>
        </div>
        <h1 data-aos="zoom-in" data-aos-delay="200">Helping <span class="highlight">Communities</span><br />Together</h1>
        <p data-aos="fade-up" data-aos-delay="300">Support Orphanages, Blind Schools, and Old Age Homes. Every donation makes a difference in someone's life.</p>
        <div class="hero-btns" data-aos="fade-up" data-aos-delay="400">
            <a href="/Donor/BrowseOrganisations" class="btn btn-primary btn-lg"><i class="bi bi-heart me-2"></i>Donate Now</a>
            <a href="/Donor/BrowseOrganisations" class="btn btn-light btn-lg"><i class="bi bi-search me-2"></i>Browse Organisations</a>
        </div>
    </div>
</section>

<!-- ─── Stats ─────────────────────────────────────────────────────────────────── -->
<section class="py-5" style="background:white; border-bottom:1px solid #e2e8f0;">
    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-md-4 col-6" data-aos="fade-up" data-aos-delay="100">
                <div class="stat-card">
                    <div class="stat-icon purple"><i class="bi bi-building"></i></div>
                    <div>
                        <div class="stat-value" data-val="@ViewBag.TotalOrgs">0</div>
                        <div class="stat-label">Active Organisations</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-6" data-aos="fade-up" data-aos-delay="200">
                <div class="stat-card">
                    <div class="stat-icon cyan"><i class="bi bi-people"></i></div>
                    <div>
                        <div class="stat-value" data-val="@ViewBag.TotalDonors">0</div>
                        <div class="stat-label">Registered Donors</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-6" data-aos="fade-up" data-aos-delay="300">
                <div class="stat-card">
                    <div class="stat-icon green"><i class="bi bi-gift"></i></div>
                    <div>
                        <div class="stat-value" data-val="@ViewBag.TotalDonations">0</div>
                        <div class="stat-label">Donations Completed</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ─── Categories with Images ─────────────────────────────────────────────── -->
<section class="section">
    <div class="container">
        <div class="text-center mb-5" data-aos="fade-up">
            <h2 class="section-title">Who We Help</h2>
            <p class="section-subtitle">We connect donors with organisations serving the most vulnerable communities</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                <div class="category-card">
                    <div class="category-img-wrapper">
                        <img src="~/images/orphanage.png" alt="Orphanage" />
                        <div class="category-img-overlay">
                            <span class="badge-pill"><i class="bi bi-house-heart me-1"></i>Explore</span>
                        </div>
                    </div>
                    <div class="category-body">
                        <h5><i class="bi bi-house-heart me-2" style="color:var(--primary)"></i>Orphanages</h5>
                        <p>Providing love, education, and warm shelter to children who need it most. Your support gives them hope for a brighter future.</p>
                        <a href="/Donor/BrowseOrganisations?type=Orphanage" class="btn btn-outline-primary btn-sm">View Orphanages <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                <div class="category-card">
                    <div class="category-img-wrapper">
                        <img src="~/images/blind-school.png" alt="Blind School" />
                        <div class="category-img-overlay">
                            <span class="badge-pill"><i class="bi bi-eye me-1"></i>Explore</span>
                        </div>
                    </div>
                    <div class="category-body">
                        <h5><i class="bi bi-eye me-2" style="color:var(--secondary)"></i>Blind Schools</h5>
                        <p>Empowering visually impaired students with education, braille tools, and skills training for an independent life.</p>
                        <a href="/Donor/BrowseOrganisations?type=BlindSchool" class="btn btn-outline-primary btn-sm">View Blind Schools <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                <div class="category-card">
                    <div class="category-img-wrapper">
                        <img src="~/images/old-age-home.png" alt="Old Age Home" />
                        <div class="category-img-overlay">
                            <span class="badge-pill"><i class="bi bi-person-arms-up me-1"></i>Explore</span>
                        </div>
                    </div>
                    <div class="category-body">
                        <h5><i class="bi bi-person-arms-up me-2" style="color:var(--success)"></i>Old Age Homes</h5>
                        <p>Caring for our elders with dignity, providing companionship, medical aid, and a comfortable home environment.</p>
                        <a href="/Donor/BrowseOrganisations?type=OldAgeHome" class="btn btn-outline-primary btn-sm">View Old Age Homes <i class="bi bi-arrow-right ms-1"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ─── Image Carousel ────────────────────────────────────────────────────────── -->
<section class="section" style="background: linear-gradient(135deg, #f0f4ff 0%, #f8fafc 100%);" data-aos="fade-up">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Making a Difference</h2>
            <p class="section-subtitle">See the impact of your generosity</p>
        </div>
        <div id="impactCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="4000">
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#impactCarousel" data-bs-slide-to="0" class="active"></button>
                <button type="button" data-bs-target="#impactCarousel" data-bs-slide-to="1"></button>
                <button type="button" data-bs-target="#impactCarousel" data-bs-slide-to="2"></button>
            </div>
            <div class="carousel-inner" style="border-radius: var(--radius); overflow:hidden; box-shadow: var(--shadow-lg);">
                <div class="carousel-item active">
                    <img src="~/images/orphanage.png" class="d-block w-100" alt="Orphanage" style="max-height:450px; object-fit:cover;" />
                    <div class="carousel-caption-custom">
                        <h5><i class="bi bi-house-heart me-2"></i>Orphanage Support</h5>
                        <p>Every child deserves a loving home, education, and a chance to dream big</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="~/images/blind-school.png" class="d-block w-100" alt="Blind School" style="max-height:450px; object-fit:cover;" />
                    <div class="carousel-caption-custom">
                        <h5><i class="bi bi-eye me-2"></i>Blind School Education</h5>
                        <p>Empowering visually impaired children with knowledge and independence</p>
                    </div>
                </div>
                <div class="carousel-item">
                    <img src="~/images/old-age-home.png" class="d-block w-100" alt="Old Age Home" style="max-height:450px; object-fit:cover;" />
                    <div class="carousel-caption-custom">
                        <h5><i class="bi bi-person-arms-up me-2"></i>Elder Care</h5>
                        <p>Providing comfort, dignity, and companionship to our beloved elders</p>
                    </div>
                </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#impactCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#impactCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>
    </div>
</section>

<!-- ─── How It Works ──────────────────────────────────────────────────────────── -->
<section class="section">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">How It Works</h2>
            <p class="section-subtitle">Simple steps to make an impact</p>
        </div>
        <div class="row g-4">
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="100">
                <div class="card text-center p-4">
                    <div style="font-size:2.5rem;margin-bottom:1rem;color:var(--primary)"><i class="bi bi-building-add"></i></div>
                    <h5 style="font-weight:700;margin-bottom:.5rem">1. Register</h5>
                    <p style="font-size:.85rem;color:var(--gray)">Organisations register and submit for admin approval. Donors sign up freely.</p>
                </div>
            </div>
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="200">
                <div class="card text-center p-4">
                    <div style="font-size:2.5rem;margin-bottom:1rem;color:var(--secondary)"><i class="bi bi-shield-check"></i></div>
                    <h5 style="font-weight:700;margin-bottom:.5rem">2. Approve</h5>
                    <p style="font-size:.85rem;color:var(--gray)">Admin reviews and approves organisations to ensure authenticity.</p>
                </div>
            </div>
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="300">
                <div class="card text-center p-4">
                    <div style="font-size:2.5rem;margin-bottom:1rem;color:var(--warning)"><i class="bi bi-list-check"></i></div>
                    <h5 style="font-weight:700;margin-bottom:.5rem">3. Post Needs</h5>
                    <p style="font-size:.85rem;color:var(--gray)">Organisations post their requirements — food, books, clothes, etc.</p>
                </div>
            </div>
            <div class="col-md-3" data-aos="fade-up" data-aos-delay="400">
                <div class="card text-center p-4">
                    <div style="font-size:2.5rem;margin-bottom:1rem;color:var(--success)"><i class="bi bi-heart-fill"></i></div>
                    <h5 style="font-weight:700;margin-bottom:.5rem">4. Donate</h5>
                    <p style="font-size:.85rem;color:var(--gray)">Donors browse, select, and send donations. Receive receipts upon acceptance.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ─── Who Can Join ──────────────────────────────────────────────────────────── -->
<section class="section" style="background:#f8fafc; border-top:1px solid #e2e8f0; border-bottom:1px solid #e2e8f0;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="section-title">Who Can Join?</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4" data-aos="zoom-in-up" data-aos-delay="100">
                <div class="card p-4" style="border-top: 4px solid var(--primary);">
                    <div style="font-size:2rem;margin-bottom:.75rem;color:var(--primary)"><i class="bi bi-shield-person"></i></div>
                    <h5 style="font-weight:700">Admin</h5>
                    <p style="font-size:.85rem;color:var(--gray);margin:0.5rem 0 1rem">Manages the entire platform — approves organisations, monitors activity, generates reports.</p>
                    <a href="/Auth/AdminLogin" class="btn btn-outline-primary btn-sm">Admin Login</a>
                </div>
            </div>
            <div class="col-md-4" data-aos="zoom-in-up" data-aos-delay="200">
                <div class="card p-4" style="border-top: 4px solid var(--secondary);">
                    <div style="font-size:2rem;margin-bottom:.75rem;color:var(--secondary)"><i class="bi bi-building"></i></div>
                    <h5 style="font-weight:700">Organisations</h5>
                    <p style="font-size:.85rem;color:var(--gray);margin:0.5rem 0 1rem">Orphanages, blind schools, old age homes post their requirements and receive donations.</p>
                    <div class="d-flex gap-2">
                        <a href="/Auth/OrgRegister" class="btn btn-outline-primary btn-sm">Register</a>
                        <a href="/Auth/OrgLogin" class="btn btn-light btn-sm">Login</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4" data-aos="zoom-in-up" data-aos-delay="300">
                <div class="card p-4" style="border-top: 4px solid var(--success);">
                    <div style="font-size:2rem;margin-bottom:.75rem;color:var(--success)"><i class="bi bi-person-heart"></i></div>
                    <h5 style="font-weight:700">Donors</h5>
                    <p style="font-size:.85rem;color:var(--gray);margin:0.5rem 0 1rem">Generous individuals who want to donate items like food, clothes, books, and more.</p>
                    <div class="d-flex gap-2">
                        <a href="/Auth/DonorRegister" class="btn btn-outline-primary btn-sm">Register</a>
                        <a href="/Auth/DonorLogin" class="btn btn-light btn-sm">Login</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            // ── Count-up animation ──
            const counters = document.querySelectorAll(".stat-value");
            const observer = new IntersectionObserver((entries, obs) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const counter = entry.target;
                        const target = +counter.getAttribute('data-val');
                        let count = 0;
                        const duration = 2000;
                        const increment = target / (duration / 16);

                        const updateCount = () => {
                            count += increment;
                            if (count < target) {
                                counter.innerText = Math.ceil(count);
                                requestAnimationFrame(updateCount);
                            } else {
                                counter.innerText = target;
                            }
                        };

                        updateCount();
                        obs.unobserve(counter);
                    }
                });
            }, { threshold: 0.5 });

            counters.forEach(counter => observer.observe(counter));
        });
    </script>
}
