@model List<SocialHelpDonation.Models.Donation>
@{ ViewData["Title"] = "All Donations"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="container"><h1><i class="bi bi-gift me-2"></i>All Donations</h1><p>Platform-wide donation activity</p></div>
</div>

<div class="container pb-5">
    <div class="table-container">
        <table>
            <thead>
                <tr><th>Receipt</th><th>Donor</th><th>Organisation</th><th>Item</th><th>Qty</th><th>Status</th><th>Date</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center py-5">
                        <div class="empty-state"><div class="empty-icon">🎁</div><h5>No Donations Yet</h5></div>
                    </td></tr>
                }
                @foreach (var d in Model)
                {
                    <tr>
                        <td><code style="font-size:.78rem">@d.ReceiptNumber</code></td>
                        <td>@(d.Donor?.Name ?? "-")</td>
                        <td>@(d.Organisation?.Name ?? "-")</td>
                        <td>@d.ItemType</td>
                        <td>@d.Quantity</td>
                        <td><span class="badge badge-@d.Status.ToString().ToLower()">@d.Status</span></td>
                        <td>@d.CreatedAt.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
