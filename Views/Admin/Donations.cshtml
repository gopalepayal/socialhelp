@model List<SocialHelpDonation.Models.Donation>
@{ ViewData["Title"] = "All Donations"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="container"><h1><i class="bi bi-gift me-2"></i>All Donations</h1><p>Platform-wide donation activity</p></div>
</div>

<div class="container pb-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i>@TempData["Success"]</div>
    }

    <div class="table-container">
        <table>
            <thead>
                <tr><th>Receipt</th><th>Donor</th><th>Organisation</th><th>Type</th><th>Details</th><th>Status</th><th>Date</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center py-5">
                        <div class="empty-state"><div class="empty-icon">🎁</div><h5>No Donations Yet</h5></div>
                    </td></tr>
                }
                @foreach (var d in Model)
                {
                    <tr>
                        <td><code style="font-size:.78rem">@d.ReceiptNumber</code></td>
                        <td>@(d.Donor?.Name ?? "-")</td>
                        <td>@(d.Organisation?.Name ?? "-")</td>
                        <td><span class="badge bg-secondary">@d.DonationType</span></td>
                        <td style="font-size:.82rem">
                            @switch (d.DonationType)
                            {
                                case SocialHelpDonation.Models.DonationType.Money:
                                    <span>₹@(d.Amount?.ToString("N0") ?? "0")</span>
                                    break;
                                case SocialHelpDonation.Models.DonationType.Food:
                                    <span>@(d.FoodType ?? "-") · @(d.MealType ?? "-") · @(d.NumberOfPlates ?? 0) plates</span>
                                    break;
                                case SocialHelpDonation.Models.DonationType.Clothes:
                                    <span>@(d.ClothCategory ?? "-") @(d.ClothType ?? "-") × @d.Quantity</span>
                                    break;
                                case SocialHelpDonation.Models.DonationType.Books:
                                    <span>@(d.BookType ?? "-") × @d.Quantity</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (d.Status == SocialHelpDonation.Models.DonationStatus.Pending)
                            { <span class="badge badge-pending"><i class="bi bi-hourglass"></i> Pending</span> }
                            else if (d.Status == SocialHelpDonation.Models.DonationStatus.Approved)
                            { <span class="badge badge-approved"><i class="bi bi-check-circle"></i> Approved</span> }
                            else if (d.Status == SocialHelpDonation.Models.DonationStatus.Rejected)
                            { <span class="badge badge-rejected"><i class="bi bi-x-circle"></i> Rejected</span> }
                            else
                            { <span class="badge badge-completed"><i class="bi bi-trophy"></i> Completed</span> }
                        </td>
                        <td>@d.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <div class="d-flex gap-2" style="flex-wrap:nowrap">
                                @if (d.Status == SocialHelpDonation.Models.DonationStatus.Pending)
                                {
                                    <form asp-controller="Admin" asp-action="ApproveDonation" method="post" style="display:inline">
                                        <input type="hidden" name="id" value="@d.Id" />
                                        <button class="btn btn-success btn-sm"><i class="bi bi-check-lg me-1"></i>Approve</button>
                                    </form>
                                }
                                <form asp-controller="Admin" asp-action="DeleteDonation" method="post" style="display:inline" onsubmit="return confirm('Are you sure you want to delete this donation?')">
                                    <input type="hidden" name="id" value="@d.Id" />
                                    <button class="btn btn-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
