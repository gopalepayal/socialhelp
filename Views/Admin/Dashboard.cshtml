@model SocialHelpDonation.Models.ViewModels.AdminReportViewModel
@{ ViewData["Title"] = "Admin Dashboard"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="container">
        <h1><i class="bi bi-speedometer2 me-2"></i>Admin Dashboard</h1>
        <p>Welcome back, @Context.Session.GetString("AdminName")</p>
    </div>
</div>

<div class="container pb-5">
    <!-- Stats Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-3 col-6">
            <div class="stat-card">
                <div class="stat-icon purple"><i class="bi bi-building"></i></div>
                <div><div class="stat-value">@Model.TotalOrgs</div><div class="stat-label">Total Orgs</div></div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card">
                <div class="stat-icon yellow"><i class="bi bi-hourglass"></i></div>
                <div><div class="stat-value">@Model.PendingOrgs</div><div class="stat-label">Pending Approval</div></div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card">
                <div class="stat-icon cyan"><i class="bi bi-people"></i></div>
                <div><div class="stat-value">@Model.TotalDonors</div><div class="stat-label">Total Donors</div></div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-gift"></i></div>
                <div><div class="stat-value">@Model.TotalDonations</div><div class="stat-label">Total Donations</div></div>
            </div>
        </div>
    </div>

    <!-- Second Row -->
    <div class="row g-4 mb-4">
        <div class="col-md-4 col-6">
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
                <div><div class="stat-value">@Model.ApprovedOrgs</div><div class="stat-label">Approved Orgs</div></div>
            </div>
        </div>
        <div class="col-md-4 col-6">
            <div class="stat-card">
                <div class="stat-icon cyan"><i class="bi bi-gift"></i></div>
                <div><div class="stat-value">@Model.ApprovedDonations</div><div class="stat-label">Approved Donations</div></div>
            </div>
        </div>
        <div class="col-md-4 col-6">
            <div class="stat-card">
                <div class="stat-icon yellow"><i class="bi bi-clock"></i></div>
                <div><div class="stat-value">@Model.PendingDonations</div><div class="stat-label">Pending Donations</div></div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-building-check me-2"></i>Manage Organisations</div>
                <div class="card-body">
                    <p style="font-size:.85rem;color:var(--gray)">Verify documents, approve or reject organisation registrations.</p>
                    <a href="/Admin/Organisations" class="btn btn-primary"><i class="bi bi-arrow-right me-1"></i>View Organisations</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-people me-2"></i>Donor Management</div>
                <div class="card-body">
                    <p style="font-size:.85rem;color:var(--gray)">View all registered donors and their contribution history.</p>
                    <a href="/Admin/Donors" class="btn btn-primary"><i class="bi bi-arrow-right me-1"></i>View Donors</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-gift me-2"></i>All Donations</div>
                <div class="card-body">
                    <p style="font-size:.85rem;color:var(--gray)">Monitor all donation activity across the system.</p>
                    <a href="/Admin/Donations" class="btn btn-primary"><i class="bi bi-arrow-right me-1"></i>View Donations</a>
                </div>
            </div>
        </div>
    </div>
</div>
