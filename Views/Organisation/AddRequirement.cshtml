@model SocialHelpDonation.Models.ViewModels.CreateRequirementViewModel
@{ ViewData["Title"] = "Add Requirement"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="container"><h1><i class="bi bi-plus-circle me-2"></i>Add Requirement</h1><p>Let donors know what you need</p></div>
</div>

<div class="container pb-5" style="max-width:600px">
    <div class="card">
        <div class="card-header"><i class="bi bi-list-check me-2"></i>New Requirement</div>
        <div class="card-body">
            <form asp-action="AddRequirement" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <div class="mb-3">
                    <label asp-for="ItemType" class="form-label"><i class="bi bi-box-seam me-1"></i>Item Type</label>
                    <input asp-for="ItemType" class="form-control" placeholder="e.g. Food, Clothes, Books, Medicines..." />
                    <span asp-validation-for="ItemType" class="field-validation-error"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="QuantityNeeded" class="form-label"><i class="bi bi-123 me-1"></i>Quantity Needed</label>
                    <input asp-for="QuantityNeeded" type="number" class="form-control" min="1" />
                    <span asp-validation-for="QuantityNeeded" class="field-validation-error"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Description" class="form-label"><i class="bi bi-card-text me-1"></i>Description (optional)</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Additional details about the requirement..."></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check2 me-1"></i>Add Requirement</button>
                    <a href="/Organisation/Requirements" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
