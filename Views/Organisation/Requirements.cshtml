@model List<SocialHelpDonation.Models.Requirement>
@{ ViewData["Title"] = "Requirements"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div><h1><i class="bi bi-list-check me-2"></i>Our Requirements</h1><p>Items your organisation needs from donors</p></div>
        <a href="/Organisation/AddRequirement" class="btn btn-primary"><i class="bi bi-plus me-1"></i>Add Requirement</a>
    </div>
</div>

<div class="container pb-5">
    <div class="table-container">
        <table>
            <thead>
                <tr><th>#</th><th>Item Type</th><th>Details</th><th>Description</th><th>Status</th><th>Posted</th><th>Action</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center py-5">
                        <div class="empty-state">
                            <div class="empty-icon">📋</div>
                            <h5>No Requirements Yet</h5>
                            <p>Add items your organisation needs.</p>
                            <a href="/Organisation/AddRequirement" class="btn btn-primary mt-3"><i class="bi bi-plus me-1"></i>Add First Requirement</a>
                        </div>
                    </td></tr>
                }
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td><span class="badge bg-secondary">@r.ItemType</span></td>
                        <td style="max-width:220px;white-space:normal;font-size:.82rem">
                            @switch (r.ItemType)
                            {
                                case SocialHelpDonation.Models.DonationType.Money:
                                    <span>₹@(r.Amount?.ToString("N0") ?? "0")</span>
                                    break;
                                case SocialHelpDonation.Models.DonationType.Food:
                                    <span>@(r.FoodType ?? "-") · @(r.MealType ?? "-") · @(r.NumberOfPlates ?? 0) plates</span>
                                    break;
                                case SocialHelpDonation.Models.DonationType.Clothes:
                                    <span>@(r.ClothCategory ?? "-") @(r.ClothType ?? "-") @(string.IsNullOrEmpty(r.Size) ? "" : $"({r.Size})") × @r.QuantityNeeded</span>
                                    break;
                                case SocialHelpDonation.Models.DonationType.Books:
                                    <span>@(r.BookType ?? "-") × @r.QuantityNeeded</span>
                                    break;
                            }
                        </td>
                        <td style="max-width:200px;white-space:normal">@(r.Description ?? "-")</td>
                        <td>
                            @if (r.Status == SocialHelpDonation.Models.RequirementStatus.Open)
                            { <span class="badge badge-open"><i class="bi bi-circle-fill" style="font-size:.5rem"></i> Open</span> }
                            else if (r.Status == SocialHelpDonation.Models.RequirementStatus.Fulfilled)
                            { <span class="badge badge-fulfilled"><i class="bi bi-check-circle"></i> Fulfilled</span> }
                            else
                            { <span class="badge badge-closed"><i class="bi bi-x-circle"></i> Closed</span> }
                        </td>
                        <td>@r.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (r.Status == SocialHelpDonation.Models.RequirementStatus.Open)
                            {
                                <form asp-action="CloseRequirement" method="post" style="display:inline">
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button class="btn btn-warning btn-sm"><i class="bi bi-x-square me-1"></i>Close</button>
                                </form>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
