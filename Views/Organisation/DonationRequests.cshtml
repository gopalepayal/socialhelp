@model List<SocialHelpDonation.Models.Donation>
@{ ViewData["Title"] = "Donation Requests"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="container"><h1><i class="bi bi-inbox me-2"></i>Donation Requests</h1><p>Review and respond to donor offers</p></div>
</div>

<div class="container pb-5">
    <div class="table-container">
        <table>
            <thead>
                <tr><th>Receipt</th><th>Donor</th><th>Type</th><th>Details</th><th>Description</th><th>Pickup</th><th>Status</th><th>Date</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center py-5">
                        <div class="empty-state"><div class="empty-icon">📬</div><h5>No Donation Requests</h5><p>Donations from donors will appear here.</p></div>
                    </td></tr>
                }
                @foreach (var d in Model)
                {
                    <tr>
                        <td><code style="font-size:.75rem">@d.ReceiptNumber</code></td>
                        <td>@(d.Donor?.Name ?? "-")<br/><small class="text-muted">@(d.Donor?.Email)</small></td>
                        <td><span class="badge bg-secondary">@d.DonationType</span></td>
                        <td style="max-width:200px;white-space:normal;font-size:.82rem">
                            @switch (d.DonationType)
                            {
                                case SocialHelpDonation.Models.DonationType.Money:
                                    <span>₹@(d.Amount?.ToString("N0") ?? "0")</span>
                                    break;
                                case SocialHelpDonation.Models.DonationType.Food:
                                    <span>@(d.FoodType ?? "-") · @(d.MealType ?? "-") · @(d.NumberOfPlates ?? 0) plates</span>
                                    break;
                                case SocialHelpDonation.Models.DonationType.Clothes:
                                    <span>@(d.ClothCategory ?? "-") @(d.ClothType ?? "-") @(string.IsNullOrEmpty(d.Size) ? "" : $"({d.Size})") × @d.Quantity</span>
                                    break;
                                case SocialHelpDonation.Models.DonationType.Books:
                                    <span>@(d.BookType ?? "-") × @d.Quantity</span>
                                    break;
                            }
                        </td>
                        <td style="max-width:150px;white-space:normal;font-size:.82rem">@(d.Description ?? "-")</td>
                        <td style="font-size:.82rem">
                            @if (d.IsPickupRequested)
                            {
                                if (d.PickupStatus == "Scheduled")
                                {
                                    <span class="badge bg-info">Scheduled<br/>@d.PickupDate?.ToString("dd MMM yyyy")</span>
                                }
                                else if (d.PickupStatus == "Requested")
                                {
                                    <span class="badge bg-warning text-dark">Requested<br/>@d.PickupDate?.ToString("dd MMM, HH:mm")</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@(d.PickupStatus ?? "Yes")<br/>@d.PickupDate?.ToString("dd MMM, HH:mm")</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted">No</span>
                            }
                        </td>
                        <td>
                            @if (d.Status == SocialHelpDonation.Models.DonationStatus.Pending)
                            { <span class="badge badge-pending"><i class="bi bi-hourglass"></i> Pending</span> }
                            else if (d.Status == SocialHelpDonation.Models.DonationStatus.Approved)
                            { <span class="badge badge-approved"><i class="bi bi-check-circle"></i> Approved</span> }
                            else if (d.Status == SocialHelpDonation.Models.DonationStatus.Rejected)
                            { <span class="badge badge-rejected"><i class="bi bi-x-circle"></i> Rejected</span> }
                            else
                            { <span class="badge badge-completed"><i class="bi bi-trophy"></i> Completed</span> }
                        </td>
                        <td>@d.CreatedAt.ToString("dd MMM yy")</td>
                        <td>
                            <div class="d-flex flex-column gap-1 mb-1">
                                <a href="/Organisation/DonationDetails/@d.Id" class="btn btn-outline-info btn-sm w-100"><i class="bi bi-eye me-1"></i>View Details</a>
                                <div class="d-flex gap-1 w-100">
                                    <a href="/Organisation/DonationDetails/@d.Id#chat-section" class="btn btn-primary btn-sm flex-fill"><i class="bi bi-chat-dots me-1"></i>Chat</a>
                                    @if(d.IsPickupRequested)
                                    {
                                        <a href="/Organisation/DonationDetails/@d.Id#pickupMap" class="btn btn-warning btn-sm flex-fill text-dark fw-bold"><i class="bi bi-geo-alt-fill me-1"></i>Track</a>
                                    }
                                </div>
                            </div>
                            @if (d.Status == SocialHelpDonation.Models.DonationStatus.Pending)
                            {
                                <div style="display:flex;flex-direction:column;gap:.3rem">
                                    <form asp-action="ApproveDonation" method="post" onsubmit="return confirm('Approve this donation?')">
                                        <input type="hidden" name="id" value="@d.Id" />
                                        <button class="btn btn-success btn-sm w-100"><i class="bi bi-check me-1"></i>Approve</button>
                                    </form>
                                    <form asp-action="RejectDonation" method="post" onsubmit="return confirm('Reject this donation?')">
                                        <input type="hidden" name="id" value="@d.Id" />
                                        <button class="btn btn-danger btn-sm w-100"><i class="bi bi-x me-1"></i>Reject</button>
                                    </form>
                                </div>
                            }
                            else if (d.Status == SocialHelpDonation.Models.DonationStatus.Approved)
                            {
                                <form asp-action="CompleteDonation" method="post" onsubmit="return confirm('Mark as completed (received)?')" class="mb-1">
                                    <input type="hidden" name="id" value="@d.Id" />
                                    <button class="btn btn-primary btn-sm w-100"><i class="bi bi-trophy me-1"></i>Mark Completed</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
