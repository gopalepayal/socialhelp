@model SocialHelpDonation.Models.Organisation
@{ ViewData["Title"] = Model?.Name + " - Profile"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="container">
        <h1><i class="bi bi-building me-2"></i>@Model?.Name</h1>
        <p><span class="badge badge-@Model?.OrgType.ToString().ToLower()">@Model?.OrgType</span> &mdash; @(Model?.Address ?? "Address not provided")</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row g-4">
        <div class="col-md-7">
            <div class="card mb-4">
                <div class="card-header"><i class="bi bi-info-circle me-2"></i>About</div>
                <div class="card-body">
                    <p>@(Model?.Description ?? "No description provided.")</p>
                    <div class="row g-2 mt-2">
                        @if (!string.IsNullOrEmpty(Model?.Phone))
                        {
                            <div class="col-6"><i class="bi bi-telephone me-1 text-primary"></i> @Model.Phone</div>
                        }
                        @if (!string.IsNullOrEmpty(Model?.Email))
                        {
                            <div class="col-6"><i class="bi bi-envelope me-1 text-primary"></i> @Model.Email</div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card">
                <div class="card-header"><i class="bi bi-list-check me-2"></i>Current Needs (@(Model?.Requirements?.Count ?? 0))</div>
                <div class="card-body">
                    @if (Model?.Requirements == null || !Model.Requirements.Any())
                    {
                        <div class="empty-state py-3">
                            <div class="empty-icon">✅</div>
                            <p>No open requirements at this time.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var r in Model.Requirements)
                        {
                            <div class="d-flex justify-content-between align-items-center py-2" style="border-bottom:1px solid var(--border)">
                                <div>
                                    <strong>@r.ItemType</strong>
                                    @if (!string.IsNullOrEmpty(r.Description)) { <br/><small class="text-muted">@r.Description</small> }
                                </div>
                                <span class="badge badge-open">Need @r.QuantityNeeded</span>
                            </div>
                        }
                    }
                    <div class="mt-3">
                        <a href="/Donor/Donate?orgId=@Model?.Id" class="btn btn-primary w-100"><i class="bi bi-heart me-1"></i>Donate to This Org</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
