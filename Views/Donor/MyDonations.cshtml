@model List<SocialHelpDonation.Models.Donation>
@{ ViewData["Title"] = "My Donations"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div><h1><i class="bi bi-gift me-2"></i>My Donations</h1><p>Track all your donation requests</p></div>
        <a href="/Donor/BrowseOrganisations" class="btn btn-primary"><i class="bi bi-plus me-1"></i>Make New Donation</a>
    </div>
</div>

<div class="container pb-5">
    <div class="table-container">
        <table>
            <thead>
                <tr><th>Receipt</th><th>Organisation</th><th>Item</th><th>Qty</th><th>Status</th><th>Date</th><th>Actions</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center py-5">
                        <div class="empty-state">
                            <div class="empty-icon">🎁</div>
                            <h5>No Donations Yet</h5>
                            <p>Start donating to organisations in need.</p>
                            <a href="/Donor/BrowseOrganisations" class="btn btn-primary mt-2">Browse Organisations</a>
                        </div>
                    </td></tr>
                }
                @foreach (var d in Model)
                {
                    <tr>
                        <td><code style="font-size:.78rem">@d.ReceiptNumber</code></td>
                        <td>@(d.Organisation?.Name ?? "-")</td>
                        <td>@d.ItemType</td>
                        <td>@d.Quantity</td>
                        <td><span class="badge badge-@d.Status.ToString().ToLower()">@d.Status</span></td>
                        <td>@d.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (d.Status == SocialHelpDonation.Models.DonationStatus.Accepted)
                            {
                                <a href="/Donor/Receipt/@d.Id" class="btn btn-primary btn-sm"><i class="bi bi-receipt me-1"></i>Receipt</a>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
