@model SocialHelpDonation.Models.ViewModels.CreateDonationViewModel
@{ ViewData["Title"] = "Make a Donation"; Layout = "~/Views/Shared/_Layout.cshtml"; }

@section Scripts {
    <!-- Leaflet CSS & JS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // -- Donation Type Fields Logic --
            const select = document.getElementById('donationTypeSelect');
            const quantityInput = document.querySelector('input[name="Quantity"]');
            const booksQtyInput = document.querySelector('.books-qty');

            if (booksQtyInput) {
                booksQtyInput.addEventListener('input', function() {
                    if (quantityInput) quantityInput.value = this.value;
                });
            }

            function updateFields() {
                document.querySelectorAll('.dynamic-field').forEach(el => {
                    el.classList.add('d-none');
                    el.classList.remove('animate-field');
                });
                
                const val = select.options[select.selectedIndex].text;
                let activeField = null;
                const commonQty = document.getElementById('commonQuantityField');
                
                if (val === 'Money') {
                    activeField = document.getElementById('moneyFields');
                    if (commonQty) commonQty.classList.add('d-none');
                } else {
                    if (commonQty) commonQty.classList.remove('d-none');
                    if (val === 'Food') {
                        activeField = document.getElementById('foodFields');
                    } else if (val === 'Clothes') {
                        activeField = document.getElementById('clothesFields');
                    } else if (val === 'Books') {
                        activeField = document.getElementById('booksFields');
                    }
                }

                if (activeField) {
                    activeField.classList.remove('d-none');
                    setTimeout(() => { activeField.classList.add('animate-field'); }, 10);
                }
            }
            
            select.addEventListener('change', updateFields);
            updateFields();

            // -- Pickup Map Logic --
            const pickupCheck = document.getElementById('pickupCheck');
            const pickupDetails = document.getElementById('pickupDetails');
            const latInput = document.getElementById('pickupLat');
            const lngInput = document.getElementById('pickupLng');
            let map = null;
            let marker = null;

            pickupCheck.addEventListener('change', function() {
                if(this.checked) {
                    pickupDetails.classList.remove('d-none');
                    // Initialize map if not already done
                    if(!map) {
                        // Default to India (can use navigator.geolocation for better UX)
                        const defaultLat = 20.5937;
                        const defaultLng = 78.9629;
                        
                        // Set map container height before init
                        document.getElementById('pickupLocationMap').style.height = '250px';
                        
                        map = L.map('pickupLocationMap').setView([defaultLat, defaultLng], 5);
                        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                            attribution: '© OpenStreetMap contributors'
                        }).addTo(map);

                        marker = L.marker([defaultLat, defaultLng], { draggable: true }).addTo(map);
                        
                        marker.on('dragend', function(e) {
                            const pos = marker.getLatLng();
                            latInput.value = pos.lat.toFixed(6);
                            lngInput.value = pos.lng.toFixed(6);
                        });

                        // Try to get user location
                        if("geolocation" in navigator) {
                            navigator.geolocation.getCurrentPosition(pos => {
                                const lat = pos.coords.latitude;
                                const lng = pos.coords.longitude;
                                map.setView([lat, lng], 15);
                                marker.setLatLng([lat, lng]);
                                latInput.value = lat.toFixed(6);
                                lngInput.value = lng.toFixed(6);
                            });
                        }
                    }
                    // Fix map sizing issues when inside a hidden div
                    setTimeout(() => { map.invalidateSize(); }, 200);
                } else {
                    pickupDetails.classList.add('d-none');
                }
            });
        });
    </script>
}

<div class="page-header" data-aos="fade-down">
    <div class="container">
        <h1><i class="bi bi-gift me-2"></i>Make a Donation</h1>
        <p>Donating to: <strong>@ViewBag.OrgName</strong></p>
    </div>
</div>

<div class="container pb-5" style="max-width:650px">
    <div class="card" data-aos="zoom-in">
        <div class="card-header"><i class="bi bi-heart me-2"></i>Donation Details</div>
        <div class="card-body">
            <form asp-action="Donate" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="OrganisationId" />
                
                <div class="mb-3">
                    <label asp-for="DonationType" class="form-label"><i class="bi bi-tags me-1"></i>Donation Category</label>
                    <select asp-for="DonationType" class="form-select" id="donationTypeSelect"
                            asp-items="Html.GetEnumSelectList<SocialHelpDonation.Models.DonationType>()">
                    </select>
                    <span asp-validation-for="DonationType" class="text-danger"></span>
                </div>

                <!-- Money Fields -->
                <div id="moneyFields" class="d-none dynamic-field bg-light p-3 rounded mb-3 border">
                    <h6 class="mb-3 text-success"><i class="bi bi-cash-coin me-1"></i>Money Donation Details</h6>
                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label">Amount (₹) <span class="text-danger">*</span></label>
                        <input asp-for="Amount" type="number" step="1" min="1" class="form-control" placeholder="Enter amount in INR" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>
                </div>

                <!-- Food Fields -->
                <div id="foodFields" class="d-none dynamic-field bg-light p-3 rounded mb-3 border">
                    <h6 class="mb-3 text-warning"><i class="bi bi-basket me-1"></i>Food Donation Details</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FoodType" class="form-label">Food Type</label>
                            <select asp-for="FoodType" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Veg">Vegetarian</option>
                                <option value="Non-Veg">Non-Vegetarian</option>
                                <option value="Packaged">Packaged</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="MealType" class="form-label">Meal Type</label>
                            <select asp-for="MealType" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Breakfast">Breakfast</option>
                                <option value="Lunch">Lunch</option>
                                <option value="Dinner">Dinner</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NumberOfPlates" class="form-label">Number of People / Plates <span class="text-danger">*</span></label>
                        <input asp-for="NumberOfPlates" type="number" min="1" class="form-control" placeholder="e.g. 50" />
                        <span asp-validation-for="NumberOfPlates" class="text-danger"></span>
                    </div>
                </div>

                <!-- Clothes Fields -->
                <div id="clothesFields" class="d-none dynamic-field bg-light p-3 rounded mb-3 border">
                    <h6 class="mb-3 text-info"><i class="bi bi-person-lines-fill me-1"></i>Clothes Donation Details</h6>
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <label asp-for="ClothCategory" class="form-label">Category</label>
                            <select asp-for="ClothCategory" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Men">Men</option>
                                <option value="Women">Women</option>
                                <option value="Kids">Kids</option>
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="ClothType" class="form-label">Type</label>
                            <select asp-for="ClothType" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="Shirt">Shirt</option>
                                <option value="Pants">Pants</option>
                                <option value="Blanket">Blanket</option>
                                <option value="Jacket">Jacket</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="ClothCondition" class="form-label">Condition</label>
                            <select asp-for="ClothCondition" class="form-select">
                                <option value="">-- Select --</option>
                                <option value="New">New</option>
                                <option value="Used">Used</option>
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Size" class="form-label">Size (Optional)</label>
                            <select asp-for="Size" class="form-select">
                                <option value="">-- Any --</option>
                                <option value="S">Small (S)</option>
                                <option value="M">Medium (M)</option>
                                <option value="L">Large (L)</option>
                                <option value="XL">Extra Large (XL)</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Books Fields -->
                <div id="booksFields" class="d-none dynamic-field bg-light p-3 rounded mb-3 border">
                    <h6 class="mb-3 text-primary"><i class="bi bi-book me-1"></i>Books Donation Details</h6>
                    <div class="mb-3">
                        <label asp-for="BookType" class="form-label">Book Type</label>
                        <select asp-for="BookType" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="Educational">Educational</option>
                            <option value="Story">Story</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                </div>

                <!-- Common Quantity (Always visible as per strict rules) -->
                <div id="commonQuantityField" class="mb-3">
                    <label asp-for="Quantity" class="form-label">Quantity <span class="text-danger">*</span></label>
                    <input asp-for="Quantity" type="number" min="1" class="form-control" placeholder="Number of items / meals" />
                    <span asp-validation-for="Quantity" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"><i class="bi bi-pencil-square me-1"></i>Description / Additional Notes (Optional)</label>
                    <textarea asp-for="Description" class="form-control" rows="2" placeholder="Tell the organisation more about your donation..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <div class="form-check mb-2">
                        <input asp-for="IsPickupRequested" class="form-check-input" type="checkbox" id="pickupCheck" />
                        <label asp-for="IsPickupRequested" class="form-check-label text-primary fw-bold" for="pickupCheck">
                            <i class="bi bi-truck me-1"></i> Request Pickup for this donation
                        </label>
                    </div>

                    <div id="pickupDetails" class="d-none bg-light p-3 rounded border">
                        <div class="mb-3">
                            <label asp-for="PickupAddress" class="form-label">Pickup Address Line</label>
                            <input asp-for="PickupAddress" class="form-control" placeholder="123 Example Street, Apt 4B" />
                        </div>
                        <div class="mb-3">
                            <label asp-for="PickupLocation" class="form-label">Pickup Location Name / Landmark (Optional)</label>
                            <input asp-for="PickupLocation" class="form-control" placeholder="e.g. Near City Park entrance" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label"><i class="bi bi-geo-alt-fill text-danger me-1"></i>Pin Exact Location on Map</label>
                            <div id="pickupLocationMap" class="w-100 rounded border shadow-sm" style="height: 0px; min-height: 250px; z-index: 1;"></div>
                            <small class="text-muted d-block mt-1">Drag the marker to your precise pickup location.</small>
                        </div>
                        <input type="hidden" asp-for="PickupLatitude" id="pickupLat" />
                        <input type="hidden" asp-for="PickupLongitude" id="pickupLng" />
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success"><i class="bi bi-send me-1"></i>Send Donation Request</button>
                    <a href="/Donor/BrowseOrganisations" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>


