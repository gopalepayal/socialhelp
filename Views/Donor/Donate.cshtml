@model SocialHelpDonation.Models.ViewModels.CreateDonationViewModel
@{ ViewData["Title"] = "Make a Donation"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="container">
        <h1><i class="bi bi-gift me-2"></i>Make a Donation</h1>
        <p>Donating to: <strong>@ViewBag.OrgName</strong></p>
    </div>
</div>

<div class="container pb-5" style="max-width:600px">
    <div class="card">
        <div class="card-header"><i class="bi bi-heart me-2"></i>Donation Details</div>
        <div class="card-body">
            <form asp-action="Donate" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <input type="hidden" asp-for="OrganisationId" />
                <div class="mb-3">
                    <label asp-for="ItemType" class="form-label"><i class="bi bi-box-seam me-1"></i>Category (Item Type)</label>
                    <input asp-for="ItemType" class="form-control" list="itemTypes" placeholder="e.g. Money, Food, Clothes..." />
                    <datalist id="itemTypes">
                        <option value="Money"></option>
                        <option value="Food"></option>
                        <option value="Clothes"></option>
                        <option value="Books"></option>
                        <option value="Medical Supplies"></option>
                        <option value="Blankets"></option>
                        <option value="Other"></option>
                    </datalist>
                    <span asp-validation-for="ItemType" class="field-validation-error"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Quantity" class="form-label"><i class="bi bi-123 me-1"></i>Quantity</label>
                    <input asp-for="Quantity" type="number" class="form-control" min="1" />
                    <span asp-validation-for="Quantity" class="field-validation-error"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Description" class="form-label"><i class="bi bi-card-text me-1"></i>Description (optional)</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe your donation..."></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success"><i class="bi bi-send me-1"></i>Send Donation Request</button>
                    <a href="/Donor/BrowseOrganisations" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
