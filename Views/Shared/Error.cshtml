@model SocialHelpDonation.ErrorViewModel
@{ ViewData["Title"] = "Error"; }

<div class="container py-5 text-center">
    <div style="font-size:4rem;margin-bottom:1rem">⚠️</div>
    <h1 class="section-title">Something went wrong</h1>
    <p class="section-subtitle">An unexpected error occurred. Please try again.</p>
    @if (Model?.ShowRequestId == true)
    {
        <p style="font-size:.8rem;color:var(--gray)">Request ID: <code>@Model.RequestId</code></p>
    }
    <a href="/" class="btn btn-primary mt-3"><i class="bi bi-house me-1"></i>Back to Home</a>
</div>
