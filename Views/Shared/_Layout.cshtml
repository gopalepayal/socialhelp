<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Community Help & Donation Management System for Orphanage, Blind Schools and Old Age Homes" />
    <title>@ViewData["Title"] - DonationSystem</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- ─── Global Loader ──────────────────────────────────────────────────────────── -->
<div id="global-loader">
    <div class="spinner"></div>
</div>

<!-- ─── Navbar ─────────────────────────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="/">
            <i class="bi bi-heart-fill" style="color:#f472b6"></i>
            Donation<span>System</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <i class="bi bi-list fs-4"></i>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house me-1"></i>Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/Donor/BrowseOrganisations"><i class="bi bi-search me-1"></i>Browse Orgs</a></li>
            </ul>
            <ul class="navbar-nav ms-auto align-items-center gap-1">
                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <li class="nav-item"><a class="nav-link" href="/Admin/Dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Organisations"><i class="bi bi-building me-1"></i>Organisations</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Admin/Donations"><i class="bi bi-gift me-1"></i>Donations</a></li>
                    <li class="nav-item">
                        <a class="nav-link btn-nav-primary" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-1"></i>Logout (@Context.Session.GetString("AdminName"))</a>
                    </li>
                }
                else if (Context.Session.GetString("UserRole") == "Organisation")
                {
                    <li class="nav-item"><a class="nav-link" href="/Organisation/Dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Organisation/Requirements"><i class="bi bi-list-check me-1"></i>Requirements</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Organisation/DonationRequests"><i class="bi bi-inbox me-1"></i>Donations</a></li>
                    <li class="nav-item">
                        <a class="nav-link btn-nav-primary" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
                    </li>
                }
                else if (Context.Session.GetString("UserRole") == "Donor")
                {
                    <li class="nav-item"><a class="nav-link" href="/Donor/Dashboard"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Donor/BrowseOrganisations"><i class="bi bi-search me-1"></i>Browse</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Donor/MyDonations"><i class="bi bi-gift me-1"></i>My Donations</a></li>
                    <li class="nav-item">
                        <a class="nav-link btn-nav-primary" href="/Auth/Logout"><i class="bi bi-box-arrow-right me-1"></i>Logout (@Context.Session.GetString("DonorName"))</a>
                    </li>
                }
                else
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown"><i class="bi bi-person-circle me-1"></i>Login</a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><h6 class="dropdown-header">Login As</h6></li>
                            <li><a class="dropdown-item" href="/Auth/AdminLogin"><i class="bi bi-shield-fill me-2 text-danger"></i>Admin</a></li>
                            <li><a class="dropdown-item" href="/Auth/OrgLogin"><i class="bi bi-building me-2 text-primary"></i>Organisation</a></li>
                            <li><a class="dropdown-item" href="/Auth/DonorLogin"><i class="bi bi-person-heart me-2 text-success"></i>Donor</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><h6 class="dropdown-header">Register As</h6></li>
                            <li><a class="dropdown-item" href="/Auth/OrgRegister"><i class="bi bi-building-add me-2 text-primary"></i>Organisation</a></li>
                            <li><a class="dropdown-item" href="/Auth/DonorRegister"><i class="bi bi-person-plus me-2 text-success"></i>Donor</a></li>
                        </ul>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- ─── Flash Messages ──────────────────────────────────────────────────────────── -->
@if (TempData["Success"] != null || TempData["Error"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3500,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.onmouseenter = Swal.stopTimer;
                    toast.onmouseleave = Swal.resumeTimer;
                }
            });

            @if (TempData["Success"] != null)
            {
                @:Toast.fire({ icon: 'success', title: '@TempData["Success"]' });
            }
            @if (TempData["Error"] != null)
            {
                @:Toast.fire({ icon: 'error', title: '@TempData["Error"]' });
            }
        });
    </script>
}

<!-- ─── Main Content ─────────────────────────────────────────────────────────────── -->
<main>
    @RenderBody()
</main>

<!-- ─── Footer ────────────────────────────────────────────────────────────────────── -->
<footer>
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <h5><i class="bi bi-heart-fill me-2" style="color:#f472b6"></i>DonationSystem</h5>
                <p>Connecting donors with organisations that need help. Building a better community together.</p>
            </div>
            <div class="col-md-2">
                <h5>Quick Links</h5>
                <ul class="list-unstyled">
                    <li><a href="/">Home</a></li>
                    <li><a href="/Donor/BrowseOrganisations">Browse Orgs</a></li>
                    <li><a href="/Auth/DonorRegister">Register as Donor</a></li>
                    <li><a href="/Auth/OrgRegister">Register Organisation</a></li>
                </ul>
            </div>
            <div class="col-md-3">
                <h5>We Support</h5>
                <ul class="list-unstyled">
                    <li><i class="bi bi-check2 me-1" style="color:#818cf8"></i>Orphanages</li>
                    <li><i class="bi bi-check2 me-1" style="color:#818cf8"></i>Blind Schools</li>
                    <li><i class="bi bi-check2 me-1" style="color:#818cf8"></i>Old Age Homes</li>
                    <li><i class="bi bi-check2 me-1" style="color:#818cf8"></i>Other NGOs</li>
                </ul>
            </div>
            <div class="col-md-3">
                <h5>Contact</h5>
                <p><i class="bi bi-envelope me-1"></i> admin@donationsystem.com<br />
                   <i class="bi bi-telephone me-1"></i> +91 00000 00000</p>
            </div>
        </div>
        <hr class="footer-divider" />
        <p class="footer-bottom">© @DateTime.Now.Year DonationSystem. All rights reserved. Built with ❤️ to help communities.</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        AOS.init({
            duration: 800,
            once: true,
            offset: 50
        });

        // ─── Global SignalR Notifications ───────────────────────────────────
        const notificationConn = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        notificationConn.on("ReceiveNotification", function(msg, type = 'info') {
            const Toast = Swal.mixin({
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 4000,
                timerProgressBar: true
            });
            Toast.fire({
                icon: type,
                title: msg
            });
        });

        notificationConn.start().catch(err => console.error(err.toString()));
    });

    window.addEventListener("load", function () {
        const loader = document.getElementById("global-loader");
        if (loader) {
            loader.style.opacity = '0';
            setTimeout(() => { loader.style.visibility = 'hidden'; }, 500);
        }
    });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
