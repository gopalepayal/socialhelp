@model SocialHelpDonation.Models.ViewModels.OrgLoginViewModel
@{ ViewData["Title"] = "Organisation Login"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon"><i class="bi bi-building"></i></div>
            <h2>Organisation Login</h2>
            <p>Access your organisation dashboard</p>
        </div>
        <div class="auth-body">
            <form asp-action="OrgLogin" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Email</label>
                    <input asp-for="Email" class="form-control" placeholder="org@example.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label"><i class="bi bi-lock me-1"></i>Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                    <div class="text-end mt-1">
                        <a href="/Auth/ForgotPassword" class="text-decoration-none small text-primary">Forgot Password?</a>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary w-100 btn-lg"><i class="bi bi-box-arrow-in-right me-2"></i>Login</button>
            </form>
        </div>
        <div class="auth-footer">New organisation? <a href="/Auth/OrgRegister">Register here</a></div>
    </div>
</div>
