@model SocialHelpDonation.Models.ViewModels.DonorLoginViewModel
@{ ViewData["Title"] = "Donor Login"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header" style="background: linear-gradient(135deg,#059669 0%,#064e3b 100%)">
            <div class="auth-icon"><i class="bi bi-person-heart"></i></div>
            <h2>Donor Login</h2>
            <p>Continue your giving journey</p>
        </div>
        <div class="auth-body">
            <form asp-action="DonorLogin" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Email</label>
                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label"><i class="bi bi-lock me-1"></i>Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="field-validation-error"></span>
                    <div class="text-end mt-1">
                        <a href="/Auth/ForgotPassword" class="text-decoration-none small">Forgot Password?</a>
                    </div>
                </div>
                <button type="submit" class="btn btn-success w-100 btn-lg"><i class="bi bi-box-arrow-in-right me-2"></i>Login</button>
            </form>
        </div>
        <div class="auth-footer">New here? <a href="/Auth/DonorRegister">Register as Donor</a></div>
    </div>
</div>
