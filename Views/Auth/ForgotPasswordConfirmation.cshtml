@{ ViewData["Title"] = "Email Sent"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="auth-wrapper">
    <div class="auth-card text-center">
        <div class="auth-header" style="padding: 3rem 2rem;">
            <div class="auth-icon bg-success mb-3" style="width: 80px; height: 80px; font-size: 2.5rem; margin: 0 auto; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: white;">
                <i class="bi bi-check-lg"></i>
            </div>
            <h2 class="mt-3">Reset Link Sent</h2>
            <p class="text-white-50">If an account exists with that email, you will receive a password reset link shortly.</p>
        </div>
        <div class="auth-body py-5">
            <p class="text-muted">Please check your inbox and spam folder. The link will expire in 15 minutes.</p>
            <a href="/Home/Index" class="btn btn-outline-primary mt-3 shadow-sm px-4">
                <i class="bi bi-house-door me-2"></i>Return to Home
            </a>
        </div>
    </div>
</div>
