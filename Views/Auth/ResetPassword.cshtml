@model SocialHelpDonation.Models.ViewModels.ResetPasswordViewModel
@{ ViewData["Title"] = "Reset Password"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header" style="background: linear-gradient(135deg, #10b981 0%, #064e3b 100%)">
            <div class="auth-icon"><i class="bi bi-shield-lock-fill"></i></div>
            <h2>Reset Password</h2>
            <p>Create a secure new password</p>
        </div>
        <div class="auth-body">
            <form asp-action="ResetPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <input type="hidden" asp-for="Email" />

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label"><i class="bi bi-lock me-1"></i>New Password</label>
                    <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="NewPassword" class="field-validation-error"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"><i class="bi bi-lock-fill me-1"></i>Confirm New Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="field-validation-error"></span>
                </div>
                <button type="submit" class="btn btn-success w-100 btn-lg shadow-sm">
                    <i class="bi bi-save2-fill me-2"></i>Update Password
                </button>
            </form>
        </div>
    </div>
</div>
