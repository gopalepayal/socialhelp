@model SocialHelpDonation.Models.ViewModels.ForgotPasswordViewModel
@{ ViewData["Title"] = "Forgot Password"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header" style="background: linear-gradient(135deg, #4f46e5 0%, #312e81 100%)">
            <div class="auth-icon"><i class="bi bi-key-fill"></i></div>
            <h2>Forgot Password</h2>
            <p>Enter your email to reset your password</p>
        </div>
        <div class="auth-body">
            <form asp-action="ForgotPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <div class="mb-4">
                    <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Email Address</label>
                    <input asp-for="Email" class="form-control" placeholder="registered@example.com" />
                    <span asp-validation-for="Email" class="field-validation-error"></span>
                </div>
                <button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm">
                    <i class="bi bi-arrow-right-circle-fill me-2"></i>Next
                </button>
            </form>
        </div>
        <div class="auth-footer">
            Remembered your password? <a href="/Home/Index">Go Back</a>
        </div>
    </div>
</div>
