@model SocialHelpDonation.Models.ViewModels.DonorRegisterViewModel
@{ ViewData["Title"] = "Donor Register"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="auth-wrapper" style="padding: 2rem 1rem;">
    <div class="auth-card" style="max-width:520px">
        <div class="auth-header" style="background: linear-gradient(135deg,#059669 0%,#064e3b 100%)">
            <div class="auth-icon"><i class="bi bi-person-heart"></i></div>
            <h2>Become a Donor</h2>
            <p>Start your journey of giving</p>
        </div>
        <div class="auth-body">
            <form asp-action="DonorRegister" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Name" class="form-label"><i class="bi bi-person me-1"></i>Full Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Your full name" />
                        <span asp-validation-for="Name" class="field-validation-error"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"><i class="bi bi-envelope me-1"></i>Email</label>
                        <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                        <span asp-validation-for="Email" class="field-validation-error"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label"><i class="bi bi-telephone me-1"></i>Phone</label>
                        <input asp-for="Phone" class="form-control" placeholder="+91 XXXXX XXXXX" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Password" class="form-label"><i class="bi bi-lock me-1"></i>Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Min 6 characters" />
                        <span asp-validation-for="Password" class="field-validation-error"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Address" class="form-label"><i class="bi bi-geo-alt me-1"></i>Address (optional)</label>
                        <input asp-for="Address" class="form-control" placeholder="Your city / area" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="btn btn-success w-100 btn-lg"><i class="bi bi-heart me-2"></i>Create Account</button>
                    </div>
                </div>
            </form>
        </div>
        <div class="auth-footer">Already a donor? <a href="/Auth/DonorLogin">Login here</a></div>
    </div>
</div>
