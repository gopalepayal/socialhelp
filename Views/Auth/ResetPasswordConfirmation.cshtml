@{ ViewData["Title"] = "Password Reset Success"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="auth-wrapper">
    <div class="auth-card text-center">
        <div class="auth-header" style="padding: 3rem 2rem; background: #059669;">
            <div class="auth-icon bg-white mb-3" style="width: 80px; height: 80px; font-size: 2.5rem; margin: 0 auto; display: flex; align-items: center; justify-content: center; border-radius: 50%; color: #059669;">
                <i class="bi bi-shield-check"></i>
            </div>
            <h2 class="mt-3">Password Updated!</h2>
            <p class="text-white-50">Your password has been reset successfully.</p>
        </div>
        <div class="auth-body py-5">
            <p class="text-muted mb-4">You can now use your new password to log in to your account.</p>
            <div class="d-grid gap-2">
                <a href="/Auth/DonorLogin" class="btn btn-success btn-lg shadow-sm">
                    <i class="bi bi-person-heart me-2"></i>Donor Login
                </a>
                <a href="/Auth/OrgLogin" class="btn btn-outline-primary btn-lg shadow-sm">
                    <i class="bi bi-building me-2"></i>Organisation Login
                </a>
            </div>
        </div>
    </div>
</div>
